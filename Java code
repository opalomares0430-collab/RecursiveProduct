package module5;

import java.util.Scanner;

public class RecursiveProduct {
  
	public static int getProduct(Scanner input, int count) {
		try {
			// Base case
			if (count == 0) {
				return 1; // neutral value for multiplication
			}
			
			System.out.print("Enter number " + count + ": ");
			int num = input.nextInt();
			
			// Recursive step
			return num * getProduct(input, count -1);
			
		} catch (Exception e) {
			System.out.println("Invalid input.");
			input.next(); // clear bad input
			return getProduct(input, count); // retry same step
		}
	}
	
	public static void main(String[] args) {
		Scanner input = new Scanner(System.in);
		
		int result = getProduct(input, 5);
		
		System.out.println("Product: " + result);
		
		input.close();
	}
            
}
