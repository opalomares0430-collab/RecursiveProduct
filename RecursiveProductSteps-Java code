package module5;

public class RecursiveProductSteps {

    public static int multiply(int[] numbers, int index) {
        // Base case
        if (index == numbers.length) {
            return 1;
        }

        // Recursive step
        int result = numbers[index] * multiply(numbers, index + 1);

        // Show each step
        System.out.println("Step result: " + result);

        return result;
    }

    public static void main(String[] args) {
        int[] nums = {2, 3, 4, 5, 6};

        int finalResult = multiply(nums, 0);

        System.out.println("Final product: " + finalResult);
    }
}
