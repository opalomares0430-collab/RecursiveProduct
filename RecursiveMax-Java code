package module5;

public class RecursiveMax {

    public static int findMax(int[] numbers, int index) {
        if (index == numbers.length - 1) {
            return numbers[index]; // base case
        }

        int max = findMax(numbers, index + 1);
        return Math.max(numbers[index], max);
    }

    public static void main(String[] args) {
        int[] nums = {2, 8, 4, 10, 6};

        int result = findMax(nums, 0);
        System.out.println("Maximum number: " + result);
    }
}
