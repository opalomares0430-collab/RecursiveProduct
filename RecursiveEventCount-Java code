package module5;

public class RecursiveEvenCount {

    public static int countEven(int[] numbers, int index) {
        if (index == numbers.length) {
            return 0; // base case
        }

        int count = (numbers[index] % 2 == 0) ? 1 : 0;
        return count + countEven(numbers, index + 1);
    }

    public static void main(String[] args) {
        int[] nums = {2, 3, 4, 5, 6};

        int result = countEven(nums, 0);
        System.out.println("Even numbers count: " + result);
    }
}
